# ============================================
# JengoRoute Backend Environment Variables
# Copy to .env and fill in real values
# ============================================

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v18.0

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=jengoroute-media

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Email Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL_FROM=alerts@jengoroute.com

# --- App Settings ---
APP_ENV=development
APP_DEBUG=true
VERIFICATION_RADIUS_METERS=200
CHECKIN_TIME_TOLERANCE_MINUTES=30

# --- Shift Scheduler (UTC times) ---
# Run: python scheduler_runner.py (alongside main app and worker)
SHIFT_START_UTC_HOUR=6
SHIFT_START_UTC_MINUTE=0
SHIFT_END_UTC_HOUR=14
SHIFT_END_UTC_MINUTE=0
MISSED_CHECKIN_DELAY_MINUTES=15
PATROL_PROMPT_OFFSET_MINUTES=240
SCHEDULER_INTERVAL_SECONDS=300
